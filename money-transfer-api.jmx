        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname=" POST user-create">
          <stringProp name="HTTPSampler.domain">mta.newroztech.com</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/api/user/create</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&#xd;
  &quot;name&quot;: &quot;${Full_Name}&quot;,&#xd;
  &quot;email&quot;: &quot;${Email}&quot;,&#xd;
  &quot;password&quot;: &quot;${Password}&quot;,&#xd;
  &quot;phone_number&quot;: &quot;${Phone_Number}&quot;,&#xd;
  &quot;nid&quot;: &quot;${Nid}&quot;,&#xd;
  &quot;role&quot;: &quot;Customer&quot;&#xd;
}&#xd;
</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Authorization</stringProp>
                <stringProp name="Header.value">Bearer ${token}</stringProp>
              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">AUTH-SECRET-KEY</stringProp>
                <stringProp name="Header.value">e97b4ca15fd2b3086c1e4af98b72d503</stringProp>
              </elementProp>
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Content-Type</stringProp>
                <stringProp name="Header.value">application/json</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <hashTree/>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">def random = new Random()

// Random name
def names = [&quot;John Smith&quot;, &quot;Jane Doe&quot;, &quot;Mike Johnson&quot;, &quot;Sara Wilson&quot;, &quot;Tom Brown&quot;]
vars.put(&quot;Full_Name&quot;, names[random.nextInt(names.size())])

// Random email
def randomNum = random.nextInt(99999)
vars.put(&quot;Email&quot;, &quot;testuser&quot; + randomNum + &quot;@dmoney.com&quot;)

// Password
vars.put(&quot;Password&quot;, &quot;test1234&quot;)

// Phone - exactly 11 digits starting with 017
def phone = &quot;017&quot; + String.format(&quot;%08d&quot;, random.nextInt(99999999))
vars.put(&quot;Phone_Number&quot;, phone)

// NID - exactly 10 digits
def nid = String.format(&quot;%010d&quot;, random.nextInt(999999999))
vars.put(&quot;Nid&quot;, nid)</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
        </hashTree>
